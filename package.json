{
  "name": "app-store-keyword-opportunity",
  "version": "0.3.0",
  "description": "Three-path AI workflow for discovering high-value App topics via trend, keyword, and replacement discovery.",
  "type": "module",
  "author": "weberwang <for.js221@gmail.com>",
  "license": "UNLICENSED",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "app-store",
    "app-ideas",
    "trend-discovery",
    "keyword-discovery",
    "replacement-opportunity",
    "typescript"
  ],
  "bin": {
  "app-store-keyword-opportunity": "./build/index.js",
  "app-store-keyword-opportunity-cli": "./build/cli.js"
  },
  "files": [
  "build/*.js",
  "build/*.d.ts",
    "README.md"
  ],
  "main": "./build/api.js",
  "types": "./build/api.d.ts",
  "exports": {
    ".": {
      "types": "./build/api.d.ts",
      "import": "./build/api.js"
    },
    "./samples": {
      "types": "./build/samples.d.ts",
      "import": "./build/samples.js"
    },
    "./package.json": "./package.json"
  },
  "packageManager": "npm@10.8.2",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weberwang/app-store-keyword-opportunity.git"
  },
  "homepage": "https://github.com/weberwang/app-store-keyword-opportunity#readme",
  "bugs": {
    "url": "https://github.com/weberwang/app-store-keyword-opportunity/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "npm run build",
  "prepublishOnly": "npm run validate",
    "prepare": "npm run build",
    "start": "node build/index.js",
    "mcp": "node build/index.js",
    "cli": "node build/cli.js",
    "sample:trend": "node build/cli.js sample trend",
    "sample:keyword": "node build/cli.js sample keyword",
    "sample:replacement": "node build/cli.js sample replacement",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "typecheck": "tsc --noEmit",
    "validate": "npm run build && node --test build/tests/workflow.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
